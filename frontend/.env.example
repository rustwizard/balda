VITE_API_BASE=/balda/api/v1
VITE_API_KEY=abcdefuvwxyz
# Public WebSocket URL seen by the browser. When empty, falls back to
# the current host (works when nginx proxies /connection/websocket).
VITE_CENTRIFUGO_WS_URL=

